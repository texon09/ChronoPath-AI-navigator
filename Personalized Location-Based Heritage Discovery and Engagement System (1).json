        "jsonBody": "={{ { \"input\": { \"text\": $json.story }, \"voice\": { \"languageCode\": \"en-US\", \"name\": \"en-US-Neural2-F\" }, \"audioConfig\": { \"audioEncoding\": \"MP3\" } } }}",
