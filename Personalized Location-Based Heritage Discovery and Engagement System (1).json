      "id": "baccbc5d-ccae-4e70-ba45-da1def6b1a0d",
      "name": "Gemini Story Generation",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        2048,
        664
      ]
    },
    {
      "parameters": {
        "jsCode": "const response = $input.item.json;\n\n// Extract the generated content from Gemini response\nlet parsedContent;\ntry {\n  const text = response.candidates[0].content.parts[0].text;\n  parsedContent = JSON.parse(text);\n} catch (error) {\n  // Fallback if parsing fails\n  parsedContent = {\n    story: 'Welcome to ' + $('Enrich Historical Context').item.json.place + '. ' + $('Enrich Historical Context').item.json.significance,\n    reasoning: $('Enrich Historical Context').item.json.cultural_relevance,\n    cultural_bridge: 'This location holds deep historical significance.',\n    historical_incident: 'Explore the rich heritage of this area.'\n  };\n}\n\nreturn [{\n  json: {\n    place: $('Enrich Historical Context').item.json.place,\n    story: parsedContent.story,\n    reasoning: parsedContent.reasoning,\n    cultural_bridge: parsedContent.cultural_bridge,\n    historical_incident: parsedContent.historical_incident,\n    trigger_type: $('Enrich Historical Context').item.json.trigger_type,\n    coordinates: {\n      lat: $('Location Tracker').item.json.body.latitude,\n      lng: $('Location Tracker').item.json.body.longitude\n    }\n  }\n}];"
      },
      "id": "a86593f3-1cc0-463a-9c66-0bbe967505f2",
      "name": "Parse Gemini Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2272,
        664
      ]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "id-1",
              "name": "place",
              "value": "={{ $('Parse Gemini Response').item.json.place }}",
              "type": "string"
            },
            {
              "id": "id-2",
              "name": "story",
              "value": "={{ $('Parse Gemini Response').item.json.story }}",
              "type": "string"
            },
            {
              "id": "id-3",
              "name": "reasoning",
              "value": "={{ $('Parse Gemini Response').item.json.reasoning }}",
              "type": "string"
            },
            {
              "id": "id-4",
              "name": "cultural_bridge",
              "value": "={{ $('Parse Gemini Response').item.json.cultural_bridge }}",
              "type": "string"
            },
            {
              "id": "id-5",
              "name": "historical_incident",
              "value": "={{ $('Parse Gemini Response').item.json.historical_incident }}",
              "type": "string"
