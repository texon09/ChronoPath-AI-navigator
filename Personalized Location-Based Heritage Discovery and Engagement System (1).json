      "id": "3f7ac85b-d922-42fd-af10-31f86c01eb3b",
      "name": "Generate Audio Narration (Gemini TTS)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        2496,
        568
      ]
    },
    {
      "parameters": {
        "jsCode": "const response = $input.item.json;\n\n// Extract the generated content from Gemini response\nlet parsedContent;\ntry {\n  const text = response.candidates[0].content.parts[0].text;\n  parsedContent = JSON.parse(text);\n} catch (error) {\n  // Fallback if parsing fails\n  parsedContent = {\n    story: 'Welcome to ' + $('Enrich Historical Context').item.json.place + '. ' + $('Enrich Historical Context').item.json.significance,\n    reasoning: $('Enrich Historical Context').item.json.cultural_relevance,\n    cultural_bridge: 'This location holds deep historical significance.',\n    historical_incident: 'Explore the rich heritage of this area.'\n  };\n}\n\nreturn [{\n  json: {\n    place: $('Enrich Historical Context').item.json.place,\n    story: parsedContent.story,\n    reasoning: parsedContent.reasoning,\n    cultural_bridge: parsedContent.cultural_bridge,\n    historical_incident: parsedContent.historical_incident,\n    trigger_type: $('Enrich Historical Context').item.json.trigger_type,\n    coordinates: {\n      lat: $('Location Tracker').item.json.body.latitude,\n      lng: $('Location Tracker').item.json.body.longitude\n    }\n  }\n}];"
      },
      "id": "ea6ff56b-8917-43d8-b321-e5d9011a6394",
      "name": "Parse Gemini Response (Lite)",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2720,
        328
      ]
    },
    {
      "parameters": {
        "jsCode": "// Loop over input items and add a new field called 'myNewField' to the JSON of each on\n// Get data from previous nodes safely\nconst place = $('Enrich Historical Context').item.json.place || 'Unknown Location';\nconst latitude = $('Location Tracker').item.json.body.latitude || '0';\nconst longitude = $('Location Tracker').item.json.body.longitude || '0';\nconst triggerType = $('Enrich Historical Context').item.json.trigger_type || 'location';\nconst significance = $('Enrich Historical Context').item.json.significance || 'Exploring the area';\nconst timeline = $('Enrich Historical Context').item.json.timeline || 'Modern era';\nconst culturalRelevance = $('Enrich Historical Context').item.json.cultural_relevance || 'Contemporary significance';\n\n// User profile\nconst userName = $('Get User Profile').first()?.json?.name || 'Guest';\nconst nationality = $('Get User Profile').first()?.json?.nationality || 'International';\nconst age = $('Get User Profile').first()?.json?.age || 'Adult';\nconst interests = $('Get User Profile').first()?.json?.interests || 'General History';\nconst language = $('Get User Profile').first()?.json?.language_preference || 'English';\n\n// Journey history\nlet journeyHistory = 'First location on journey';\ntry {\n  const historyArray = $('Get User Journey History').all();\n  if (historyArray.length > 0) {\n    journeyHistory = historyArray\n      .map(loc => `${loc.json.location_name} at ${loc.json.timestamp}`)\n      .join(', ');\n  }\n} catch (e) {\n  journeyHistory = 'First location on journey';\n}\n\n// Heritage data (safe stringify)\nlet heritageData = '{}';\ntry {\n  heritageData = JSON.stringify($('Enrich Historical Context').item.json.heritage_data || {});\n} catch (e) {\n  heritageData = '{}';\n}\n\n// Build prompt\nconst promptText = `You are ChronoPath AI, a Digital Ancestor guiding travelers through Pune's rich history.\n\nCURRENT CONTEXT:\nLocation: ${place}\nCoordinates: ${latitude}, ${longitude}\nTrigger Type: ${triggerType}\nHistorical Significance: ${significance}\nTimeline: ${timeline}\nCultural Relevance: ${culturalRelevance}\n\nUSER PROFILE:\nName: ${userName}\nNationality: ${nationality}\nAge: ${age}\nInterests: ${interests}\nLanguage: ${language}\n\nPREVIOUS JOURNEY:\n${journeyHistory}\n\nHERITAGE DATA:\n${heritageData}\n\nTASK:\nGenerate an immersive, personalized historical narrative.\n\nRespond ONLY in valid JSON:\n{\n  \"story\": \"...\",\n  \"reasoning\": \"...\",\n  \"cultural_bridge\": \"...\",\n  \"historical_incident\": \"...\"\n}\n\nAdapt storytelling to user's profile. Make it immersive and meaningful.`;\n\n// FINAL OUTPUT (VERY IMPORTANT — do NOT change this structure)\nreturn [\n  {\n    json: {\n      contents: [\n        {\n          parts: [\n            {\n              text: promptText\n            }\n          ]\n        }\n      ],\n      generationConfig: {\n        temperature: 0.8,\n        topK: 40,\n        topP: 0.95,\n        maxOutputTokens: 2048,\n        responseMimeType: \"application/json\"\n      }\n    }\n  }\n];\n\n"
      },
