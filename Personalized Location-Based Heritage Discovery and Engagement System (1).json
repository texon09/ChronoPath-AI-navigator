    {
      "parameters": {
        "jsCode": "const lat = parseFloat($('Location Tracker').item.json.body.latitude);\nconst lng = parseFloat($('Location Tracker').item.json.body.longitude);\nconst heritageData = $input.item.json.elements || [];\n\n// Known landmarks in Pune with coordinates\nconst landmarks = [\n  { name: 'Shaniwar Wada', lat: 18.5196, lng: 73.8553, radius: 200, type: 'historical_incident', significance: 'Seat of Peshwa rulers, site of 1828 fire tragedy', timeline: '1732-1818', cultural_relevance: 'Symbol of Maratha Empire power' },\n  { name: 'Aga Khan Palace', lat: 18.5515, lng: 73.9015, radius: 150, type: 'location', significance: 'Prison for Mahatma Gandhi during Quit India Movement', timeline: '1942-1944', cultural_relevance: 'Independence movement memorial' },\n  { name: 'Sinhagad Fort', lat: 18.3664, lng: 73.7556, radius: 300, type: 'location', significance: 'Site of Battle of Sinhagad (1670)', timeline: '2000+ years old', cultural_relevance: 'Maratha military heritage' },\n  { name: 'Dagdusheth Halwai Ganpati Temple', lat: 18.5167, lng: 73.8560, radius: 100, type: 'location', significance: 'Cultural and religious center since 1893', timeline: '1893-present', cultural_relevance: 'Living tradition of Ganesh worship' },\n  { name: 'Pataleshwar Cave Temple', lat: 18.5074, lng: 73.8436, radius: 80, type: 'location', significance: '8th century rock-cut temple', timeline: '8th century CE', cultural_relevance: 'Ancient Rashtrakuta architecture' }\n];\n\n// Calculate distance using Haversine formula\nfunction getDistance(lat1, lon1, lat2, lon2) {\n  const R = 6371e3; // Earth radius in meters\n  const φ1 = lat1 * Math.PI/180;\n  const φ2 = lat2 * Math.PI/180;\n  const Δφ = (lat2-lat1) * Math.PI/180;\n  const Δλ = (lon2-lon1) * Math.PI/180;\n  const a = Math.sin(Δφ/2) * Math.sin(Δφ/2) +\n          Math.cos(φ1) * Math.cos(φ2) *\n          Math.sin(Δλ/2) * Math.sin(Δλ/2);\n  const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));\n  return R * c;\n}\n\n// Find nearest landmark\nlet nearestLandmark = null;\nlet minDistance = Infinity;\n\nfor (const landmark of landmarks) {\n  const distance = getDistance(lat, lng, landmark.lat, landmark.lng);\n  if (distance < landmark.radius && distance < minDistance) {\n    minDistance = distance;\n    nearestLandmark = landmark;\n  }\n}\n\n// Determine trigger type and context\nlet result = {\n  place: nearestLandmark ? nearestLandmark.name : 'Unknown Location',\n  trigger_type: nearestLandmark ? nearestLandmark.type : 'location',\n  distance_meters: Math.round(minDistance),\n  within_zone: nearestLandmark !== null,\n  significance: nearestLandmark ? nearestLandmark.significance : 'Exploring Pune',\n  timeline: nearestLandmark ? nearestLandmark.timeline : 'Modern era',\n  cultural_relevance: nearestLandmark ? nearestLandmark.cultural_relevance : 'Contemporary urban area',\n  coordinates: { lat, lng },\n  heritage_elements_found: heritageData.length\n};\n\nreturn [result];"
      },
