    {
      "parameters": {
        "schemaType": "manual",
        "inputSchema": "{\n\t\"type\": \"object\",\n\t\"properties\": {\n\t\t\"location_name\": {\n\t\t\t\"type\": \"string\",\n\t\t\t\"description\": \"Name of the heritage location\"\n\t\t},\n\t\t\"historical_significance\": {\n\t\t\t\"type\": \"string\",\n\t\t\t\"description\": \"Why this location matters historically\"\n\t\t},\n\t\t\"audio_script\": {\n\t\t\t\"type\": \"string\",\n\t\t\t\"description\": \"Conversational narration script for text-to-speech (2-3 minutes, engaging storytelling)\"\n\t\t},\n\t\t\"visual_description\": {\n\t\t\t\"type\": \"string\",\n\t\t\t\"description\": \"Detailed description for AI image generation showing historical scene or cultural context\"\n\t\t},\n\t\t\"text_summary\": {\n\t\t\t\"type\": \"string\",\n\t\t\t\"description\": \"Brief key points (3-5 bullet points, not text-heavy)\"\n\t\t},\n\t\t\"cultural_analogy\": {\n\t\t\t\"type\": \"string\",\n\t\t\t\"description\": \"Relatable comparison for the user's nationality\"\n\t\t}\n\t},\n\t\"required\": [\"location_name\", \"historical_significance\", \"audio_script\", \"visual_description\", \"text_summary\", \"cultural_analogy\"]\n}"
      },
