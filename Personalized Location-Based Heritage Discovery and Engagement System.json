    {
      "parameters": {
        "url": "https://overpass-api.de/api/interpreter",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "data",
              "value": "=[\n  out:json];\n  (\n    node[\"historic\"](around:500,{{ $json.body.latitude }},{{ $json.body.longitude }});\n    node[\"tourism\"=\"attraction\"](around:500,{{ $json.body.latitude }},{{ $json.body.longitude }});\n    node[\"tourism\"=\"museum\"](around:500,{{ $json.body.latitude }},{{ $json.body.longitude }});\n    way[\"historic\"](around:500,{{ $json.body.latitude }},{{ $json.body.longitude }});\n    way[\"tourism\"=\"attraction\"](around:500,{{ $json.body.latitude }},{{ $json.body.longitude }});\n  );\n  out body;\n  >;\n  out skel qt;"
            }
          ]
        },
        "options": {
          "response": {
            "response": {
              "neverError": true,
              "responseFormat": "json"
            }
          }
        }
      },
      "id": "846f8f62-1cd1-4195-a16b-2aa648d14788",
